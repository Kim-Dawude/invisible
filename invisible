-- // Localisation & Fixes
local cloneref = cloneref or function(...) return ... end

local gethui = gethui or game:GetService("CoreGui") and function()
    return cloneref(game:GetService("CoreGui"))
end or function()
    return game:GetService("Players").LocalPlayer:FindFirstChildWhichIsA("PlayerGui")
end

local RunService = cloneref(game:GetService("RunService"))
local Players = cloneref(game:GetService("Players"))

local LocalPlayer = Players.LocalPlayer
local HiddenUi = gethui()

local Highlight = nil

local Character = LocalPlayer.Character
local Humanoid = Character and Character:FindFirstChildWhichIsA("Humanoid")
local RootPart = Humanoid and Humanoid.RootPart
local Old = RootPart and RootPart.CFrame or CFrame.new()

-- Notification Function
local function notify(title, text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

LocalPlayer.CharacterAdded:Connect(function(C)
    Character = C
    Humanoid = C:WaitForChild("Humanoid")
    RootPart = Humanoid.RootPart
    Old = RootPart.CFrame
    if Highlight then
        Highlight.Adornee = C
    end
end)

LocalPlayer.CharacterRemoving:Connect(function(C)
    if C ~= Character then return end
    Character = nil
    Humanoid = nil
    RootPart = nil
end)

local PrimaryRenderStepName = (function()
	local buff = buffer.create(20)
	local charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
	local clen = #charset
	for i = 1, 20 do
		local c = charset:byte(math.random(1, clen))
		buffer.writeu8(buff, i - 1, c)
	end
	return buffer.tostring(buff)
end)()

local SecondaryRenderStepName = PrimaryRenderStepName:reverse()

local AccurateCharacterRepresentation = false
local VerticalOffset = -Vector3.yAxis * 7
local Rotation90 = CFrame.Angles(math.rad(90), 0, 0)

local Connections = {}
local RenderStepsBinded = {}
local Enabled = false

-- // Core Functions
local function fakeinvis()
    if Enabled then return end
    Enabled = true
    Old = RootPart and RootPart.CFrame

    if AccurateCharacterRepresentation then
        table.insert(RenderStepsBinded, PrimaryRenderStepName)
        RunService:BindToRenderStep(PrimaryRenderStepName, Enum.RenderPriority.Camera.Value - 5, function()
            if not RootPart then return end
            RootPart.CFrame = Old
            if Highlight then Highlight.Enabled = true end
        end)

        table.insert(RenderStepsBinded, SecondaryRenderStepName)
        RunService:BindToRenderStep(SecondaryRenderStepName, Enum.RenderPriority.Camera.Value + 5, function()
            if not RootPart then return end
            RootPart.CFrame = CFrame.new(RootPart.Position + VerticalOffset) * Rotation90
        end)

        table.insert(Connections, RunService.PreAnimation:Connect(function()
            if not RootPart then return end
            RootPart.CFrame = Old
        end))
        
        table.insert(Connections, RunService.PostSimulation:Connect(function()
            if not RootPart then return end
            Old = RootPart.CFrame
            RootPart.CFrame = CFrame.new(RootPart.Position + VerticalOffset) * Rotation90
        end))
        notify("Fake Invis", "Activated!")
        return
    end

    table.insert(RenderStepsBinded, PrimaryRenderStepName)
    RunService:BindToRenderStep(PrimaryRenderStepName, Enum.RenderPriority.Camera.Value - 1, function()
        if not RootPart then return end
        RootPart.CFrame = Old
    end)

    table.insert(Connections, RunService.PostSimulation:Connect(function()
        if not RootPart then return end
        Old = RootPart.CFrame
        RootPart.CFrame = CFrame.new(RootPart.Position + VerticalOffset) * Rotation90
    end))
    notify("Fake Invis", "Activated!")
end

local function unfakeinvis()
    if not Enabled then return end

    for _, Connection in next, Connections do
        Connection:Disconnect()
    end
    table.clear(Connections)

    for _, RenderStep in next, RenderStepsBinded do
        RunService:UnbindFromRenderStep(RenderStep)
    end

    if RootPart then
        RootPart.CFrame = Old
    end

    Enabled = false
    if Highlight then
        Highlight.Enabled = false
    end
    notify("Fake Invis", "Deactivated!")
end

-- // Chat Command Handler
local Prefix = ";" -- Aap isko "/" ya apni marzi ka prefix set kar sakte hain

local function ChatHandler(msg)
    msg = string.lower(msg)
    
    -- Check if message starts with prefix
    if string.sub(msg, 1, #Prefix) == Prefix then
        local args = string.split(string.sub(msg, #Prefix + 1), " ")
        local cmd = args[1]
        
        -- 1. Fake Invis Commands
        if cmd == "fakeinvis" or cmd == "fakeinvisibility" or cmd == "finvis" then
            fakeinvis()
            
        -- 2. Unfake Invis Commands
        elseif cmd == "unfakeinvis" or cmd == "unfakeinvisibility" or cmd == "unfinvis" then
            unfakeinvis()
            
        -- 3. Set Vertical Offset
        elseif cmd == "setverticaloffset" or cmd == "setvo" then
            local number = tonumber(args[2])
            if not number then
                notify("Invalid Input", "Number expected! Example: " .. Prefix .. "setvo 10")
                return
            end
            VerticalOffset = -Vector3.yAxis * math.abs(number)
            notify("Offset Changed", "New offset: " .. tostring(number))
            
        -- 4. Accurate Character Representation
        elseif cmd == "accuratecharrep" or cmd == "acr" then
            AccurateCharacterRepresentation = true
            if Enabled then
                unfakeinvis()
                fakeinvis()
            end
            notify("Accurate Rep", "Enabled")
            
        -- 5. Unaccurate Character Representation
        elseif cmd == "unaccuratecharrep" or cmd == "unacr" then
            AccurateCharacterRepresentation = false
            if Enabled then
                unfakeinvis()
                fakeinvis()
            end
            notify("Accurate Rep", "Disabled")
            
        -- 6. Highlight Character
        elseif cmd == "highlightcharrep" or cmd == "hcr" then
            if Highlight then return end
            local _Highlight = Instance.new("Highlight", HiddenUi)
            _Highlight.Adornee = Character
            _Highlight.Enabled = false
            Highlight = _Highlight
            notify("Highlight", "Enabled")
            
        -- 7. Unhighlight Character
        elseif cmd == "unhighlightcharrep" or cmd == "unhcr" then
            if not Highlight then return end
            Highlight:Destroy()
            Highlight = nil
            notify("Highlight", "Disabled")
        end
    end
end

-- Hooking into player chat
LocalPlayer.Chatted:Connect(ChatHandler)

notify("CMD System Loaded", "Use commands in chat! Example: ;fakeinvis")
